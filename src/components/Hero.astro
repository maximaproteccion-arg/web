---
import { Image } from "astro:assets";
import { empresa } from "../data/empresa";
import CtaWhatsapp from "./CtaWhatsapp.astro";
import fondoHero from "../assets/hero-sensor-puerta.png";
---

<section class="relative overflow-hidden border-b border-navy/10">
  <Image
    src={fondoHero}
    alt=""
    aria-hidden="true"
    widths={[828, 1280, 1920, 2560]}
    sizes="100vw"
    quality={70}
    format="webp"
    loading="eager"
    fetchpriority="high"
    class="absolute inset-0 h-full w-full object-cover object-[72%_center]"
  />
  <div
    class="absolute inset-0 bg-gradient-to-t from-white via-white/85 to-white/5 md:bg-gradient-to-r md:from-white/95 md:via-white/65 md:to-transparent"
  >
  </div>

  <!-- Notificación flotante: el producto en acción, sin explicarlo -->
  <div
    class="anim-rise-4 absolute top-8 right-3 w-64 rounded-2xl border border-white/60 bg-white/75 p-3.5 shadow-lg backdrop-blur-md md:top-24 md:right-12 md:w-72"
    aria-hidden="true"
  >
    <div class="flex items-center gap-2.5">
      <span class="relative flex size-10 shrink-0 items-center justify-center rounded-xl bg-navy text-gold">
        <svg
          class="size-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9Zm-4.27 13a2 2 0 0 1-3.46 0" />
        </svg>
        <span class="absolute -top-1 -right-1 flex size-2.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-gold opacity-75"></span>
          <span class="relative inline-flex size-2.5 rounded-full bg-gold"></span>
        </span>
      </span>
      <div class="min-w-0 flex-1">
        <p class="flex items-baseline justify-between gap-2 text-[10px] font-bold tracking-wide text-navy/50 uppercase">
          <span>Mi alarma</span>
          <span class="normal-case">ahora</span>
        </p>
        <p class="truncate text-sm font-bold text-navy">Apertura detectada</p>
        <p class="truncate text-xs text-navy/60">Puerta de entrada · Aviso al instante</p>
      </div>
    </div>
  </div>

  <div class="relative mx-auto flex max-w-6xl items-end px-4 pt-44 pb-12 sm:pt-48 md:min-h-[600px] md:items-center md:py-28">
    <div class="max-w-xl">
      <p
        class="anim-rise inline-flex items-center gap-2 rounded-full border border-navy/10 bg-white/80 px-3.5 py-1.5 text-[11px] font-extrabold tracking-widest text-navy/70 uppercase backdrop-blur sm:text-xs"
      >
        <span class="relative flex size-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-gold opacity-75"></span>
          <span class="relative inline-flex size-2 rounded-full bg-gold"></span>
        </span>
        Alarma automonitoreada · Sin abono
      </p>
      <h1
        class="anim-rise-1 mt-4 text-[2rem] leading-[1.12] font-extrabold tracking-tight text-navy text-balance sm:text-4xl md:text-5xl"
      >
        Si esa puerta se abre, vos lo sabés
        <span class="rounded bg-gradient-to-r from-gold/45 to-gold/20 box-decoration-clone px-1">
          al instante.
        </span>
      </h1>
      <p class="anim-rise-2 mt-5 max-w-prose text-base leading-relaxed text-navy/70 sm:text-lg">
        Tu casa te avisa a tu celular, estés donde estés. Instalada y garantizada
        por la empresa que hace más de {empresa.anios} años protege a los platenses.
      </p>
      <div class="anim-rise-2 mt-7">
        <CtaWhatsapp grande />
      </div>
      <div class="anim-rise-3 mt-6 flex flex-wrap gap-2">
        <span
          class="rounded-full border border-navy/10 bg-white/80 px-4 py-1.5 text-xs font-bold text-navy shadow-sm backdrop-blur"
        >
          Más de {empresa.anios} años en {empresa.ciudad}
        </span>
        <span
          class="rounded-full border border-navy/10 bg-white/80 px-4 py-1.5 text-xs font-bold text-navy shadow-sm backdrop-blur"
        >
          Prestadora N° {empresa.prestadora} · Min. de Seguridad PBA
        </span>
      </div>
    </div>
  </div>
</section>
